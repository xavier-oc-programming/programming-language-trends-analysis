# Copy this file to .env and fill in your values.

# ── Adzuna API ───────────────────────────────────────────────────────
# Register free at https://developer.adzuna.com
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
# Options: gb | us | au | ca | de | fr | in | nz | pl | ru | za
ADZUNA_COUNTRY=gb

# ── GitHub API ───────────────────────────────────────────────────────
# Classic PAT — no special scopes needed for public repo search
# Generate at https://github.com/settings/tokens
# NOTE: SSH keys are for git operations; this is a separate token for the REST API
GITHUB_TOKEN=your_github_pat_here
